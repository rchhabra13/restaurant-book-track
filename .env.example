# ── MongoDB ────────────────────────────────────────────────────────────
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=restaurant_tracker

# ── Telegram Bot ──────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. The bot auto-detects each user's chat_id; TELEGRAM_CHAT_ID is the
#    fallback chat for Streamlit-initiated alerts.
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=

# ── WhatsApp via Twilio (optional) ────────────────────────────────────
# Sign up at twilio.com → Messaging → Try WhatsApp → scan sandbox QR.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=

# ── Resy ──────────────────────────────────────────────────────────────
# API key: Network tab on resy.com → look for `Authorization: ResyAPI api_key="..."`.
RESY_API_KEY=
# OPTIONAL: log in once on resy.com, then DevTools → Application → Cookies →
# copy resy_token cookie here. Bypasses auto-login (avoids HTTP 419 rate limit).
RESY_AUTH_TOKEN=
RESY_EMAIL=
RESY_PASSWORD=

# ── OpenTable (optional) ──────────────────────────────────────────────
OPENTABLE_EMAIL=
OPENTABLE_PASSWORD=

# ── Outbound proxy ────────────────────────────────────────────────────
# Use when your home IP gets banned by Resy. Format: scheme://user:pass@host:port
# HTTPS_PROXY=

# ── Scraping ──────────────────────────────────────────────────────────
REQUEST_DELAY_SECONDS=5
REQUEST_TIMEOUT=15

# ── Scheduler ─────────────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=15
BURST_CHECK_INTERVAL_SECONDS=10
BURST_WINDOW_MINUTES=15

# ── Alerts ────────────────────────────────────────────────────────────
ALERT_COOLDOWN_MINUTES=60
# Quiet hours (24h, local time per QUIET_HOURS_TZ).  Set both to same value to disable.
QUIET_HOURS_START=0
QUIET_HOURS_END=0
QUIET_HOURS_TZ=America/New_York

# ── Observability ─────────────────────────────────────────────────────
# Sentry: paste DSN from sentry.io project settings to enable error reporting.
SENTRY_DSN=
# Healthz HTTP server (returns liveness JSON). 0 disables.
HEALTHZ_PORT=8090
HEALTHZ_BIND=127.0.0.1

# ── Browser-extension bridge ──────────────────────────────────────────
# Local HTTP server that receives slot data from the Chrome extension
# (see extension/README.md). 127.0.0.1 means loopback-only.
INGEST_PORT=8091
INGEST_BIND=127.0.0.1
# Optional shared secret — when set, extension must send `X-Token: <value>`
INGEST_TOKEN=
